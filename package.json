{
  "name": "corporate-signage-saas",
  "version": "0.1.0",
  "private": true,
  "description": "SaaS de TV corporativa e mural de avisos digital signage.",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,yml,yaml,css}\"",
    "docker:up": "docker compose up --build"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.5.4"
  }
}
